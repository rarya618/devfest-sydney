{
  "apphosting": {
    "backendId": "devfest-sydney",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ],
    "alwaysDeployFromSource": true
  },
  "firestore": {
    "database": "(default)",
    "location": "australia-southeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "DevFest Sydney",
        "supportEmail": "russalarya@gmail.com",
        "authorizedRedirectUris": [
          "http://localhost",
          "https://devfest.gdgsydney.com",
          "https://devfest-sydney--devfest-sydney-2026.asia-southeast1.hosted.app"
        ]
      }
    }
  }
}
