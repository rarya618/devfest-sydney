{
  "apphosting": {
    "backendId": "devfest-sydney",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "australia-southeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "DevFest Sydney",
        "supportEmail": "russalarya@gmail.com",
        "authorizedRedirectUris": ["http://localhost:3000"]
      }
    }
  }
}
